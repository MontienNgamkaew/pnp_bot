PORT=3000

# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token

# Google Drive service account.
# Use ONE of these:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Parent folder where the bot will create/use Images, Videos, and Documents folders.
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# Optional: use existing folders instead of auto-creating subfolders.
# GOOGLE_DRIVE_IMAGE_FOLDER_ID=
# GOOGLE_DRIVE_VIDEO_FOLDER_ID=
# GOOGLE_DRIVE_DOCUMENT_FOLDER_ID=

# Optional: wait time before sending one summary message for uploaded files.
SUMMARY_DELAY_SECONDS=45

# Optional: MySQL database for appointment commands.
# Appointment commands are disabled until these values are configured.
# DB_HOST=your_mysql_host
# DB_PORT=3306
# DB_USER=your_mysql_user
# DB_PASSWORD=your_mysql_password
# DB_NAME=your_mysql_database

# Optional: appointment reminder settings.
REMINDER_MORNING_HOUR=7
REMINDER_CHECK_INTERVAL_SECONDS=60
